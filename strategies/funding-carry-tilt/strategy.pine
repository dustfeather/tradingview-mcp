//@version=6
// funding-carry-tilt — LOCKED DESIGN, SIGNAL FORK OPEN (scaffold 2026-06-07)
// Survey rank #1. See plan.md / spec.md. Instrument BYBIT:BTCUSDT.P, daily.
//
// Edge = harvest persistently-signed funding (revenue), not price prediction.
// Symmetric: short when funding persistently positive, long when persistently negative.
// NOTE: TradingView Pine cannot read Bybit funding history directly; the authoritative
// net is the EXTERNAL fold (Bybit klines + scripts/funding_fold.js). This Pine encodes
// the PRICE-leg entry/exit logic; funding revenue is applied in the external fold.
strategy("funding-carry-tilt", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, process_orders_on_close=true, calc_on_every_tick=false)

// === Pre-registered anchors (spec.md) ===
kStamps     = input.int(21,   "Funding lookback (8h stamps ≈ days*3)")
thrShort    = input.float(0.0033, "Short-carry funding threshold %/8h", step=0.0001)
thrLong     = input.float(-0.0033,"Long-carry funding threshold %/8h",  step=0.0001)
holdCapDays = input.int(30,   "Hold cap (days)")
atrLen      = input.int(14,   "ATR length")
atrMult     = input.float(3.0,"ATR stop mult", step=0.5)

// === SIGNAL FORK (OPEN) ============================================================
// Funding series is not available natively in Pine for Bybit perps. Wire one of:
//   (a) a manual funding-EMA input / external feed, or
//   (b) run the decision in the external fold and use this Pine only for price-leg viz.
// Placeholder funding proxy = 0 → no trades until the fork is wired. DO NOT backtest in TV;
// trust the external fold per RESEARCH.md lesson #6.
fundingEmaProxy = 0.0   // TODO: replace with real K-stamp funding EMA (external)

shortCarry = fundingEmaProxy >= thrShort
longCarry  = fundingEmaProxy <= thrLong
// ===================================================================================

atr = ta.atr(atrLen)
if longCarry and strategy.position_size <= 0
    strategy.entry("L", strategy.long)
if shortCarry and strategy.position_size >= 0
    strategy.entry("S", strategy.short)
if not longCarry and not shortCarry
    strategy.close_all("flat")

// ATR price-leg stop (guards the unhedged leg — the #1 risk)
if strategy.position_size > 0
    strategy.exit("Lx", "L", stop=strategy.position_avg_price - atrMult*atr)
if strategy.position_size < 0
    strategy.exit("Sx", "S", stop=strategy.position_avg_price + atrMult*atr)
