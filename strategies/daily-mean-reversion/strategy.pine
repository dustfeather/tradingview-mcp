//@version=6
// daily-mean-reversion — LOCKED DESIGN, SIGNAL FORK OPEN (scaffold 2026-06-07)
// Survey rank #4 (diversifier). See plan.md / spec.md. Instrument BYBIT:BTCUSDT.P, daily.
//
// Edge = fade multi-day overextension, only with the SMA(200) regime. Must beat always-fade in
// ablation and survive turnover-heavy friction. Authoritative net = external fold.
strategy("daily-mean-reversion", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, process_orders_on_close=true, calc_on_every_tick=false)

// === Pre-registered anchors (spec.md) ===
rsiLen   = input.int(2,   "RSI length")
loThr    = input.float(10, "Long entry RSI <", step=1)
hiThr    = input.float(90, "Short entry RSI >", step=1)
useTrend = input.bool(true, "SMA(200) trend filter")
trendLen = input.int(200, "Trend SMA length")
exitLen  = input.int(5,   "Exit SMA length")
atrLen   = input.int(14,  "ATR length")
atrMult  = input.float(3.0,"ATR stop mult", step=0.5)

// ablation toggle: false ⇒ always-fade (threshold removed, fade any cross of mid)
thrEnabled = input.bool(true, "ABLATION: overextension threshold enabled")

r   = ta.rsi(close, rsiLen)
sma200 = ta.sma(close, trendLen)
sma5   = ta.sma(close, exitLen)

upRegime = not useTrend or close > sma200
dnRegime = not useTrend or close < sma200

longSig  = thrEnabled ? (r < loThr and upRegime) : (close < sma5 and upRegime)
shortSig = thrEnabled ? (r > hiThr and dnRegime) : (close > sma5 and dnRegime)

if longSig and strategy.position_size <= 0
    strategy.entry("L", strategy.long)
if shortSig and strategy.position_size >= 0
    strategy.entry("S", strategy.short)

// revert-to-mean exit
if strategy.position_size > 0 and close > sma5
    strategy.close("L", comment="revert")
if strategy.position_size < 0 and close < sma5
    strategy.close("S", comment="revert")

atr = ta.atr(atrLen)
if strategy.position_size > 0
    strategy.exit("Lx", "L", stop=strategy.position_avg_price - atrMult*atr)
if strategy.position_size < 0
    strategy.exit("Sx", "S", stop=strategy.position_avg_price + atrMult*atr)
