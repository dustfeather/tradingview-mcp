//@version=6
indicator(title='Fear Bottom Finder', shorttitle='FearBtm', overlay=true, max_labels_count=100)

// ============ INPUTS ============
// --- Symbol factors ---
ddMax      = input.float(20.0, 'Drawdown % for max score',           minval=1.0,  group='Symbol Factors')
rsiFloor   = input.int(25,     'RSI floor (max fear)',               minval=1, maxval=49, group='Symbol Factors')
stretchMax = input.float(15.0, 'Stretch % below 200MA for max score', minval=1.0, group='Symbol Factors')
volMult    = input.float(2.0,  'Capitulation volume x 20-bar avg',   minval=1.0,  group='Symbol Factors')

// --- Market factors ---
useMarketData = input.bool(true,  'Use S&P market factors',          group='Market Factors')
usePutCall    = input.bool(true,  'Use Put/Call ratio (USI:PCC)',    group='Market Factors')

// --- Composite ---
topN = input.int(4, 'Factors averaged (strongest N)', minval=1, maxval=8, group='Composite', tooltip='Fear Score = average of the N highest-scoring factors. Lower N = more reactive (a few alarmed factors lift the score); higher N = more agreement required.')

// --- Tiers ---
cautionT = input.int(40, 'Caution threshold', minval=1, maxval=98, group='Tiers')
fearT    = input.int(60, 'Fear threshold',    minval=2, maxval=99, group='Tiers')
extremeT = input.int(80, 'Extreme threshold', minval=3, maxval=99, group='Tiers')

// --- Buy zone ---
buyThresh = input.int(80, 'Buy zone min fear score', minval=10, maxval=99, group='Buy Zone', tooltip='Lowest fear score that can trigger a buy. 60 = FEAR tier (orange) and above, 80 = EXTREME only (red).')

// --- Display ---
verbose = input.bool(false, 'Verbose breakdown table', group='Display')

// ============ HELPERS ============
// Map val into 0-100, clamped. Works with loVal>hiVal (inverted) too.
scale(float val, float loVal, float hiVal) =>
    na(val) ? na : math.min(math.max((val - loVal) / (hiVal - loVal) * 100.0, 0.0), 100.0)

// ============ SYMBOL FACTORS ============
hh252      = ta.highest(close, 252)
ddPct      = (hh252 - close) / hh252 * 100.0
ddScore    = scale(ddPct, 0.0, ddMax)

rsiVal     = ta.rsi(close, 14)
rsiScore   = scale(rsiVal, 50.0, rsiFloor)          // inverted bounds: RSI 50 -> 0, rsiFloor -> 100

sma200     = ta.sma(close, 200)
stretchPct = (sma200 - close) / sma200 * 100.0
stretchScore = scale(stretchPct, 0.0, stretchMax)

hh22close  = ta.highest(close, 22)
wvf        = (hh22close - low) / hh22close * 100.0
wvfScore   = ta.percentrank(wvf, 252)               // already 0-100

// ============ MARKET FACTORS ============
// VIX vs its own 50-day SMA. Ratio > 1 = elevated fear.
vixClose = useMarketData ? request.security('CBOE:VIX', 'D', close)               : na
vixSma   = useMarketData ? request.security('CBOE:VIX', 'D', ta.sma(close, 50))   : na
vixRatio = na(vixClose) or na(vixSma) ? na : vixClose / vixSma
vixScore = scale(vixRatio, 1.0, 1.5)

// Junk bond demand: HYG/LQD ratio falling = credit stress = fear.
hygClose  = useMarketData ? request.security('AMEX:HYG', 'D', close) : na
lqdClose  = useMarketData ? request.security('AMEX:LQD', 'D', close) : na
junkRatio = na(hygClose) or na(lqdClose) ? na : hygClose / lqdClose
junkAvg   = ta.sma(junkRatio, 50)
junkScore = na(junkRatio) or na(junkAvg) ? na : scale(junkRatio, junkAvg * 1.02, junkAvg * 0.92)

// Safe-haven demand: SPX 20d return minus TLT 20d return. Negative = flight to bonds.
// The return is computed INSIDE request.security so the [20] offset is 20 daily
// bars regardless of the chart timeframe (correct on intraday charts too).
spxRet    = useMarketData ? request.security('SP:SPX',     'D', (close - close[20]) / close[20] * 100.0) : na
tltRet    = useMarketData ? request.security('NASDAQ:TLT', 'D', (close - close[20]) / close[20] * 100.0) : na
havenDiff = na(spxRet) or na(tltRet) ? na : spxRet - tltRet
havenScore = scale(havenDiff, 5.0, -10.0)           // inverted: +5% stocks lead -> 0, -10% -> 100

// Put/Call ratio. Behind its own sub-toggle: USI:PCC can be na on some plans.
pccClose = usePutCall ? request.security('USI:PCC', 'D', close)             : na
pccAvg   = usePutCall ? request.security('USI:PCC', 'D', ta.sma(close, 20)) : na
pccRatio = na(pccClose) or na(pccAvg) ? na : pccClose / pccAvg
pcScore  = scale(pccRatio, 0.95, 1.4)

// ============ COMPOSITE ============
// Fear Score = average of the topN strongest factors. A plain average of all 8
// would be diluted by factors sitting near 0, so the score could never reach the
// high tiers. Averaging only the strongest factors lets genuine, multi-factor
// fear actually register. na factors (e.g. a missing feed) are simply not added.
var liveScores = array.new<float>()
array.clear(liveScores)
if not na(ddScore)
    array.push(liveScores, ddScore)
if not na(rsiScore)
    array.push(liveScores, rsiScore)
if not na(wvfScore)
    array.push(liveScores, wvfScore)
if not na(stretchScore)
    array.push(liveScores, stretchScore)
if not na(vixScore)
    array.push(liveScores, vixScore)
if not na(junkScore)
    array.push(liveScores, junkScore)
if not na(havenScore)
    array.push(liveScores, havenScore)
if not na(pcScore)
    array.push(liveScores, pcScore)
array.sort(liveScores, order.descending)
nUse = math.min(topN, array.size(liveScores))
float fearScore = na
if nUse > 0
    float acc = 0.0
    for i = 0 to nUse - 1
        acc += array.get(liveScores, i)
    fearScore := acc / nUse

// ============ TIERS ============
tier = na(fearScore) ? 0 : fearScore >= extremeT ? 3 : fearScore >= fearT ? 2 : fearScore >= cautionT ? 1 : 0

bgCol = tier == 3 ? color.new(color.red, 80) : tier == 2 ? color.new(color.orange, 85) : tier == 1 ? color.new(color.yellow, 88) : na
bgcolor(bgCol, title='Fear Tier Background')

// ============ BUY ZONE ============
// Buy when fear is at or above buyThresh AND an exhaustion trigger confirms
// (capitulation volume, or Williams VIX Fix rolling off an elevated peak).
inBuyZone = not na(fearScore) and fearScore >= buyThresh
capVol  = volume > ta.sma(volume, 20) * volMult
wvfRoll = wvf < wvf[1] and wvf[1] >= wvf[2] and wvfScore[1] > 80
buyZone = inBuyZone and (capVol or wvfRoll)

// One primary buy per calendar month; later qualifying bars are secondary.
newMonth = ta.change(month(time)) != 0
var bool boughtThisMonth = false
if newMonth
    boughtThisMonth := false
primaryBuy = buyZone and not boughtThisMonth
if primaryBuy
    boughtThisMonth := true
secondaryBuy = buyZone and boughtThisMonth and not primaryBuy

plotshape(primaryBuy,   title='Primary Buy',   location=location.belowbar, style=shape.triangleup, size=size.normal, color=color.new(color.green, 0),  text='BUY')
plotshape(secondaryBuy, title='Secondary Buy', location=location.belowbar, style=shape.circle,     size=size.tiny,   color=color.new(color.green, 40))

plot(ddScore,      title='ddScore',      display=display.data_window)
plot(rsiScore,     title='rsiScore',     display=display.data_window)
plot(wvfScore,     title='wvfScore',     display=display.data_window)
plot(stretchScore, title='stretchScore', display=display.data_window)
plot(vixScore,     title='vixScore',     display=display.data_window)
plot(junkScore,    title='junkScore',    display=display.data_window)
plot(havenScore,   title='havenScore',   display=display.data_window)
plot(pcScore,      title='pcScore',      display=display.data_window)
plot(fearScore, title='Fear Score', display=display.data_window)

// ============ DISPLAY TABLE ============
tierName = tier == 3 ? 'EXTREME FEAR' : tier == 2 ? 'FEAR' : tier == 1 ? 'CAUTION' : 'NEUTRAL'
// Color the table by BUY OPPORTUNITY (not by fear): gray when there is nothing to
// do (low fear), turning progressively greener as fear deepens, bright green at
// EXTREME fear = the buy zone. Green always means "buy" — matching the BUY marker.
// All cell colors are fully OPAQUE and clearly lighter than the dark chart so the
// table reads as a solid panel.
tierCol = tier == 3 ? color.rgb(0, 175, 0) : tier == 2 ? color.rgb(30, 130, 30) : tier == 1 ? color.rgb(70, 110, 70) : color.rgb(120, 120, 120)
cellHdr = color.rgb(95, 100, 110)
cellSub = color.rgb(75, 80, 90)

// Sub-scores are 0-100 readings, shown as percentages.
f_cellStr(float sc) => na(sc) ? 'n/a' : str.tostring(math.round(sc)) + '%'

var table t = table.new(position.middle_left, 2, 10, border_width=1)
if barstate.islast
    table.cell(t, 0, 0, 'Fear Score', text_color=color.white, bgcolor=cellHdr)
    table.cell(t, 1, 0, f_cellStr(fearScore), text_color=color.white, bgcolor=tierCol)
    table.cell(t, 0, 1, 'Tier', text_color=color.white, bgcolor=cellHdr)
    table.cell(t, 1, 1, tierName, text_color=color.white, bgcolor=tierCol)
    if verbose
        table.cell(t, 0, 2, 'Drawdown',  text_color=color.white, bgcolor=cellSub)
        table.cell(t, 1, 2, f_cellStr(ddScore),      text_color=color.white, bgcolor=cellSub)
        table.cell(t, 0, 3, 'RSI',       text_color=color.white, bgcolor=cellSub)
        table.cell(t, 1, 3, f_cellStr(rsiScore),     text_color=color.white, bgcolor=cellSub)
        table.cell(t, 0, 4, 'WVF',       text_color=color.white, bgcolor=cellSub)
        table.cell(t, 1, 4, f_cellStr(wvfScore),     text_color=color.white, bgcolor=cellSub)
        table.cell(t, 0, 5, 'Stretch',   text_color=color.white, bgcolor=cellSub)
        table.cell(t, 1, 5, f_cellStr(stretchScore), text_color=color.white, bgcolor=cellSub)
        table.cell(t, 0, 6, 'VIX',       text_color=color.white, bgcolor=cellSub)
        table.cell(t, 1, 6, f_cellStr(vixScore),     text_color=color.white, bgcolor=cellSub)
        table.cell(t, 0, 7, 'Junk',      text_color=color.white, bgcolor=cellSub)
        table.cell(t, 1, 7, f_cellStr(junkScore),    text_color=color.white, bgcolor=cellSub)
        table.cell(t, 0, 8, 'Haven',     text_color=color.white, bgcolor=cellSub)
        table.cell(t, 1, 8, f_cellStr(havenScore),   text_color=color.white, bgcolor=cellSub)
        table.cell(t, 0, 9, 'Put/Call',  text_color=color.white, bgcolor=cellSub)
        table.cell(t, 1, 9, f_cellStr(pcScore),      text_color=color.white, bgcolor=cellSub)
