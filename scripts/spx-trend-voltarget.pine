//@version=6
// =============================================================================
// SPX Trend + Volatility Target  (Engine A)
// =============================================================================
// A RISK REDUCER, not a return forecaster. Equity-index returns are ~unpredictable
// short-horizon, but two things ARE: (1) volatility clusters, (2) big drawdowns
// unfold slowly below trend. This harvests both.
//
//   GATE  (when to be long): close > long MA  → trend up, else flat (cash).
//   SIZE  (how much):        position ∝ target_vol / realized_vol, capped at
//                            max_lev. De-risks when vol spikes (tail-risk).
//   REBAL: continuously rebalance to the target notional with a dead-band to
//          limit churn (strategy.order on the signed diff).
//
// VALIDATED RESULT (long/flat only, daily):
//   • Robust, EVERY-period edge = DRAWDOWN REDUCTION — ~1/3 of buy-hold's maxDD
//     (SPY 1993-2026: 18% vs 56%; SPCFD 1871-2026: 32% vs 42%).
//   • SHARPE-beat is PERIOD-DEPENDENT: decisive over 1871-2026 (deep bears to
//     dodge), only a TIE over the 1993-2026 bull. Claim the drawdown cut, not a
//     general Sharpe edge.
//   • Lever to taste: 1.5x ~ best Sharpe+DD (ties buy-hold Sharpe, 1/3 DD);
//     2.0x ~ matches buy-hold CAGR with 1/3 DD (costs some Sharpe to drag).
//   • Param surface smooth (ma 150-250, vol 0.10-0.20, SMA/EMA) — not overfit.
//
// CAVEATS: in-sample full history; SPCFD early data understates the 1929 tail;
// TV Sharpe is non-standard (relative ranking only); leverage assumes borrow ~rf.
// =============================================================================

// NOTE on sizing: every order below passes an explicit qty (computed notional),
// so default_qty_* would never be consulted and is omitted. Rebalance legs use
// strategy.order, which is NOT affected by `pyramiding` — so no pyramiding
// setting is needed to allow scaling into the position. margin_long=0 permits
// notional > equity when max_lev > 1 (intended leverage).
strategy("SPX Trend + VolTarget", overlay = true, calc_on_every_tick = false,
         initial_capital = 10000, commission_type = strategy.commission.percent,
         commission_value = 0.02, margin_long = 0.0)

grp_gate = "Trend gate"
grp_size = "Vol targeting"

ma_len     = input.int(200,  title = "Trend MA length (bars)", minval = 20, maxval = 400, group = grp_gate, tooltip = "Long only when close is above this SMA. ~200d = Faber-style 10-month trend filter.")
ma_type    = input.string("SMA", title = "Trend MA type", options = ["SMA","EMA"], group = grp_gate)

vol_lb     = input.int(20,    title = "Realized-vol lookback (bars)", minval = 5, maxval = 100, group = grp_size, tooltip = "Window for realized volatility (stdev of log returns).")
target_vol = input.float(0.15, title = "Target annual vol", minval = 0.02, maxval = 0.50, step = 0.01, group = grp_size, tooltip = "Annualized volatility the position is sized to. Position fraction = target_vol / realized_vol.")
max_lev    = input.float(1.5,  title = "Max leverage", minval = 0.1, maxval = 5.0, step = 0.1, group = grp_size, tooltip = "Cap on position notional / equity. 1.0 = no leverage (best Sharpe / min DD). 1.5 = strong all-round (ties buy-hold Sharpe at ~1/3 the drawdown). 2.0 ~ matches buy-hold CAGR at ~1/3 the drawdown. Higher = more CAGR + DD, lower Sharpe (drag).")
rebal_band = input.float(0.10, title = "Rebalance dead-band", minval = 0.01, maxval = 0.50, step = 0.01, group = grp_size, tooltip = "Only rebalance when target notional drifts more than this fraction from current. Limits churn/commissions.")

// ── Trend gate ───────────────────────────────────────────────────────────────
ma        = ma_type == "EMA" ? ta.ema(close, ma_len) : ta.sma(close, ma_len)
trend_up  = not na(ma) and close > ma

// ── Vol-target sizing ────────────────────────────────────────────────────────
ret    = math.log(close / close[1])
rvol   = ta.stdev(ret, vol_lb) * math.sqrt(252)
lev    = na(rvol) or rvol <= 0 ? 0.0 : math.min(max_lev, target_vol / rvol)

// Desired signed notional (in units of the instrument). Flat when below trend.
desired_qty = trend_up ? (strategy.equity * lev) / close : 0.0

// ── Rebalance to target with dead-band ──────────────────────────────────────
if barstate.isconfirmed
    diff = desired_qty - strategy.position_size
    band = math.max(desired_qty * rebal_band, na(rvol) ? 1e18 : 0.0)  // when no vol yet, band huge → no trade
    if desired_qty == 0 and strategy.position_size > 0
        strategy.close_all()
    else if diff > band and diff > 0
        strategy.order("up", strategy.long, qty = diff)
    else if -diff > band and diff < 0
        strategy.order("dn", strategy.short, qty = -diff)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(ma, "Trend MA", color = color.new(color.orange, 0))
bgcolor(trend_up ? color.rgb(132, 187, 161, 92) : color.rgb(197, 127, 134, 92), title = "Trend gate")
