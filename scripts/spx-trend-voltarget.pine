//@version=6
// =============================================================================
// SPX Trend + Volatility Target  (Engine A)
// =============================================================================
// A RISK REDUCER, not a return forecaster. Equity-index returns are ~unpredictable
// short-horizon, but two things ARE: (1) volatility clusters, (2) big drawdowns
// unfold slowly below trend. This harvests both.
//
//   GATE  (when to be long): close > long MA  → trend up, else flat (cash).
//   SIZE  (how much):        position ∝ target_vol / realized_vol, capped at
//                            max_lev. De-risks when vol spikes (tail-risk).
//   REBAL: continuously rebalance to the target notional with a dead-band to
//          limit churn (strategy.order on the signed diff).
//
// VALIDATED RESULT (long/flat only, daily; fitted for Alpaca — $0 commission,
// 6.25% margin on the BORROWED slice, modelled in the net equity curve below):
//   • Robust, EVERY-period edge = DRAWDOWN REDUCTION — roughly HALF buy-hold's
//     maxDD (SPY 1993-2026 net: ~24% vs ~56%).
//   • Net of margin it does NOT beat buy-hold CAGR: SPY 1993-2026 net CAGR ~8.4%
//     vs buy-hold 10.85%. You trade ~2.5pp CAGR for ~half the drawdown.
//   • LEVERAGE SWEET SPOT = 1.5x: net 8.35% CAGR / 24% DD. (1.0x: 7.62% / 19%,
//     zero margin; 2.0x: 8.40% / 25% — financing eats the extra leverage, so
//     past 1.5x you add drawdown for ~no net return.)
//   • Sharpe-beat is period-dependent (decisive over 1871-2026's deep bears;
//     ~tie over the 1993-2026 bull). Claim the drawdown cut, not a Sharpe edge.
//   • Param surface smooth (ma 150-250, vol 0.10-0.20, SMA/EMA) — not overfit.
//   • eToro is UNVIABLE leveraged: CFD overnight (~10%/yr on FULL notional)
//     erases the return; eToro only works at 1x real stock.
//
// CAVEATS: in-sample full history; SPCFD early data understates the 1929 tail;
// TV's own Sharpe/maxDD are non-standard (relative only) — the net table here is
// the honest read; Pine can't debit interest so financing is a shadow curve.
// =============================================================================

// NOTE on sizing: every order below passes an explicit qty (computed notional),
// so default_qty_* would never be consulted and is omitted. Rebalance legs use
// strategy.order, which is NOT affected by `pyramiding` — so no pyramiding
// setting is needed to allow scaling into the position. margin_long=0 permits
// notional > equity when max_lev > 1 (intended leverage).
// Fitted for ALPACA: stock commission = $0 (reg fees negligible). Leverage =
// margin loan charged ONLY on the borrowed slice at ~6.25%/yr — modelled below
// as a net-of-financing equity curve (Pine can't debit interest natively).
strategy("SPX Trend + VolTarget", overlay = true, calc_on_every_tick = false,
         initial_capital = 10000, commission_type = strategy.commission.percent,
         commission_value = 0.0, margin_long = 0.0)

grp_gate = "Trend gate"
grp_size = "Vol targeting"
grp_fee  = "Broker financing (Alpaca)"

ma_len     = input.int(200,  title = "Trend MA length (bars)", minval = 20, maxval = 400, group = grp_gate, tooltip = "Long only when close is above this SMA. ~200d = Faber-style 10-month trend filter.")
ma_type    = input.string("SMA", title = "Trend MA type", options = ["SMA","EMA"], group = grp_gate)

vol_lb     = input.int(20,    title = "Realized-vol lookback (bars)", minval = 5, maxval = 100, group = grp_size, tooltip = "Window for realized volatility (stdev of log returns).")
target_vol = input.float(0.15, title = "Target annual vol", minval = 0.02, maxval = 0.50, step = 0.01, group = grp_size, tooltip = "Annualized volatility the position is sized to. Position fraction = target_vol / realized_vol.")
max_lev    = input.float(1.5,  title = "Max leverage", minval = 0.1, maxval = 5.0, step = 0.1, group = grp_size, tooltip = "Cap on position notional / equity. 1.0 = no leverage (best Sharpe / min DD). 1.5 = strong all-round (ties buy-hold Sharpe at ~1/3 the drawdown). 2.0 ~ matches buy-hold CAGR at ~1/3 the drawdown. Higher = more CAGR + DD, lower Sharpe (drag).")
rebal_band = input.float(0.10, title = "Rebalance dead-band", minval = 0.01, maxval = 0.50, step = 0.01, group = grp_size, tooltip = "Only rebalance when target notional drifts more than this fraction from current. Limits churn/commissions.")

financing_pct = input.float(6.25, title = "Margin rate (%/yr)", minval = 0.0, maxval = 20.0, step = 0.25, group = grp_fee, tooltip = "Annual interest charged on the BORROWED slice (notional - equity). Alpaca standard ~6.25% (5% Elite). Drives the net-of-financing equity curve in the diagnostics table.")

// ── Trend gate ───────────────────────────────────────────────────────────────
ma        = ma_type == "EMA" ? ta.ema(close, ma_len) : ta.sma(close, ma_len)
trend_up  = not na(ma) and close > ma

// ── Vol-target sizing ────────────────────────────────────────────────────────
ret    = math.log(close / close[1])
rvol   = ta.stdev(ret, vol_lb) * math.sqrt(252)
lev    = na(rvol) or rvol <= 0 ? 0.0 : math.min(max_lev, target_vol / rvol)

// Desired signed notional (in units of the instrument). Flat when below trend.
desired_qty = trend_up ? (strategy.equity * lev) / close : 0.0

// ── Rebalance to target with dead-band ──────────────────────────────────────
if barstate.isconfirmed
    diff = desired_qty - strategy.position_size
    band = math.max(desired_qty * rebal_band, na(rvol) ? 1e18 : 0.0)  // when no vol yet, band huge → no trade
    if desired_qty == 0 and strategy.position_size > 0
        strategy.close_all()
    else if diff > band and diff > 0
        strategy.order("up", strategy.long, qty = diff)
    else if -diff > band and diff < 0
        strategy.order("dn", strategy.short, qty = -diff)

// ── Net-of-financing equity curve (Alpaca margin on the borrowed slice) ──────
// Pine can't debit margin interest natively, so we shadow a NET equity curve:
// each bar, net return = strategy's gross return − (borrowed/equity)·rate/252,
// compounded. Reports gross vs net CAGR + maxDD so the realistic Alpaca result
// is visible. Read via data_get_pine_tables.
var float notl_sum   = 0.0
var float borrow_sum = 0.0
var int   nbars      = 0
var int   nin        = 0
var float net_eq     = na
var float prev_geq   = na
var float gpeak      = na
var float npeak      = na
var float gmaxdd     = 0.0
var float nmaxdd     = 0.0

if barstate.isconfirmed
    geq = strategy.equity
    pv  = strategy.position_size * close
    borrowed = math.max(0.0, pv - geq)
    fin_ret  = geq > 0 ? (borrowed * (financing_pct / 100.0) / 252.0) / geq : 0.0
    notl_sum   := notl_sum   + pv / geq
    borrow_sum := borrow_sum + borrowed / geq
    nbars      := nbars + 1
    nin        := nin + (strategy.position_size != 0 ? 1 : 0)
    if na(net_eq)
        net_eq := geq
        prev_geq := geq
        gpeak := geq
        npeak := geq
    else
        gret = geq / prev_geq - 1.0
        net_eq := net_eq * (1.0 + gret - fin_ret)
        prev_geq := geq
        gpeak := math.max(gpeak, geq)
        npeak := math.max(npeak, net_eq)
        gmaxdd := math.max(gmaxdd, (gpeak - geq) / gpeak)
        nmaxdd := math.max(nmaxdd, (npeak - net_eq) / npeak)

var table tdiag = table.new(position.bottom_left, 2, 6, bgcolor = color.new(color.black, 15), border_width = 1, border_color = color.gray)
if barstate.islast and nbars > 1
    yrs   = nbars / 252.0
    init  = strategy.initial_capital
    gcagr = (math.pow(strategy.equity / init, 1.0 / yrs) - 1.0) * 100.0
    ncagr = (math.pow(net_eq / init, 1.0 / yrs) - 1.0) * 100.0
    table.cell(tdiag, 0, 0, "gross CAGR",     text_color = color.gray,  text_size = size.normal)
    table.cell(tdiag, 1, 0, str.tostring(gcagr, "#.##") + "%", text_color = color.gray, text_size = size.normal)
    table.cell(tdiag, 0, 1, "NET CAGR (Alpaca)", text_color = color.lime, text_size = size.normal)
    table.cell(tdiag, 1, 1, str.tostring(ncagr, "#.##") + "%", text_color = color.lime, text_size = size.normal)
    table.cell(tdiag, 0, 2, "gross maxDD",    text_color = color.gray,  text_size = size.normal)
    table.cell(tdiag, 1, 2, str.tostring(gmaxdd * 100.0, "#.#") + "%", text_color = color.gray, text_size = size.normal)
    table.cell(tdiag, 0, 3, "NET maxDD",      text_color = color.orange, text_size = size.normal)
    table.cell(tdiag, 1, 3, str.tostring(nmaxdd * 100.0, "#.#") + "%", text_color = color.orange, text_size = size.normal)
    table.cell(tdiag, 0, 4, "avg borrowed",   text_color = color.white, text_size = size.normal)
    table.cell(tdiag, 1, 4, str.tostring(100.0 * borrow_sum / nbars, "#.##") + "%", text_color = color.white, text_size = size.normal)
    table.cell(tdiag, 0, 5, "avg expo / in-mkt", text_color = color.white, text_size = size.normal)
    table.cell(tdiag, 1, 5, str.tostring(notl_sum / nbars, "#.##") + "x / " + str.tostring(100.0 * nin / nbars, "#.#") + "%", text_color = color.white, text_size = size.normal)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(ma, "Trend MA", color = color.new(color.orange, 0))
bgcolor(trend_up ? color.rgb(132, 187, 161, 92) : color.rgb(197, 127, 134, 92), title = "Trend gate")
